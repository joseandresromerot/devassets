{
  "name": "@devassets/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "prisma generate && prisma migrate deploy && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@devassets/types": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "@prisma/client": "6.19.2",
    "fastify": "^5.3.2",
    "pino-pretty": "^13.1.3",
    "stripe": "^17.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "prisma": "6.19.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
